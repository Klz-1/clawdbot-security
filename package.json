{
  "name": "clawdbot-security",
  "version": "0.1.0",
  "description": "Comprehensive security management system for Clawdbot - automated hardening, CVE tracking, and compliance reporting",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clawdbot-security": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "clawdbot",
    "security",
    "hardening",
    "cve",
    "audit",
    "compliance",
    "nginx",
    "fail2ban"
